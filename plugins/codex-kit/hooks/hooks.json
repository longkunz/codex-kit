{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/user_prompt_secret_scan.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "bash|shell|exec|powershell",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/pre_tool_use_policy.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/stop_validation.mjs"
          }
        ]
      }
    ]
  }
}
